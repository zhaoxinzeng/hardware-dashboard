{
  "name": "-demo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173 --strictPort --open",
    "dev:dashboard": "vite --host 0.0.0.0 --port 5173 --strictPort --open",
    "dev:calculator": "bash ./scripts/dev-calculator.sh 3001 0.0.0.0",
    "predev:all": "lsof -t -i tcp:5173 | xargs kill -9 2>/dev/null; lsof -t -i tcp:3001 | xargs kill -9 2>/dev/null; true",
    "dev:all": "concurrently \"npm:dev:dashboard\" \"npm:dev:calculator\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "fetch-news": "node scripts/fetch-news.js"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@google/genai": "^1.43.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.24",
    "axios": "^1.13.5",
    "cheerio": "^1.2.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "openai": "^6.25.0",
    "postcss": "^8.5.6",
    "rss-parser": "^3.13.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
